{
  "kind": "sdkwork.api.assembly",
  "schemaVersion": 1,
  "applicationCode": "music",
  "apiMode": "served",
  "packageName": "sdkwork-api-music-assembly",
  "crateDir": "crates/sdkwork-api-music-assembly",
  "routeCrates": [
    {
      "packageName": "sdkwork-routes-music-app-api",
      "memberDir": "crates/sdkwork-routes-music-app-api",
      "libName": "sdkwork_routes_music_app_api",
      "surface": "app-api",
      "pathPrefix": "/app/v3/api",
      "mountOrder": 0,
      "componentRef": "crates/sdkwork-routes-music-app-api/specs/component.spec.json",
      "routeManifestRef": "crates/sdkwork-routes-music-app-api/sdks/_route-manifests/<surface>/<packageName>.route-manifest.json",
      "sourceRef": "crates/sdkwork-routes-music-app-api/Cargo.toml"
    },
    {
      "packageName": "sdkwork-routes-music-backend-api",
      "memberDir": "crates/sdkwork-routes-music-backend-api",
      "libName": "sdkwork_routes_music_backend_api",
      "surface": "backend-api",
      "pathPrefix": "/backend/v3/api",
      "mountOrder": 1,
      "componentRef": "crates/sdkwork-routes-music-backend-api/specs/component.spec.json",
      "routeManifestRef": "crates/sdkwork-routes-music-backend-api/sdks/_route-manifests/<surface>/<packageName>.route-manifest.json",
      "sourceRef": "crates/sdkwork-routes-music-backend-api/Cargo.toml"
    }
  ]
}
