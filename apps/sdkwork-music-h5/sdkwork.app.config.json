{
  "schemaVersion": 2,
  "appId": "sdkwork-music-h5",
  "appName": "SDKWork Music H5",
  "appDescription": "SDKWork Music H5 application for mobile web and Capacitor",
  "owner": "sdkwork-music",
  "domain": "music",
  "capability": "music-h5",
  "runtime": {
    "family": "mobile",
    "framework": "react",
    "renderer": "browser",
    "platforms": [
      "WEB",
      "IOS",
      "ANDROID"
    ],
    "supportedDeploymentProfiles": [
      "cloud",
      "standalone"
    ],
    "defaultDeploymentProfile": "cloud"
  },
  "publish": {
    "platforms": [
      "WEB",
      "IOS",
      "ANDROID"
    ],
    "artifactPrefix": "sdkwork-music-h5"
  },
  "backend": {
    "appId": "sdkwork-music",
    "apiAuthority": "sdkwork-music-backend-api"
  },
  "appApi": {
    "apiAuthority": "sdkwork-music-app-api",
    "sdkFamily": "sdkwork-music-app-sdk"
  },
  "envBindings": {
    "development": {
      "VITE_API_BASE_URL": "http://127.0.0.1:18080",
      "VITE_APP_API_PREFIX": "/app/v3/api",
      "VITE_BACKEND_API_PREFIX": "/backend/v3/api"
    },
    "test": {
      "VITE_API_BASE_URL": "https://test-api.sdkwork-music.com",
      "VITE_APP_API_PREFIX": "/app/v3/api",
      "VITE_BACKEND_API_PREFIX": "/backend/v3/api"
    },
    "staging": {
      "VITE_API_BASE_URL": "https://staging-api.sdkwork-music.com",
      "VITE_APP_API_PREFIX": "/app/v3/api",
      "VITE_BACKEND_API_PREFIX": "/backend/v3/api"
    },
    "production": {
      "VITE_API_BASE_URL": "https://api.sdkwork-music.com",
      "VITE_APP_API_PREFIX": "/app/v3/api",
      "VITE_BACKEND_API_PREFIX": "/backend/v3/api"
    }
  },
  "sdkDependencies": [
    {
      "workspace": "sdkwork-music-app-sdk",
      "role": "music-app-capability",
      "required": true,
      "dependencyMode": "consumer-sdk"
    }
  ],
  "devApp": {
    "build": {
      "targets": {
        "web": {
          "command": "pnpm build",
          "output": "dist"
        },
        "ios": {
          "command": "pnpm build:ios",
          "output": "ios/App/App/Info.plist"
        },
        "android": {
          "command": "pnpm build:android",
          "output": "android/app/build/outputs/apk"
        }
      }
    }
  }
}
